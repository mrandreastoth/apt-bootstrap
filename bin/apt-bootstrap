#!/usr/bin/env bash
# apt-bootstrap -- Step-based server provisioning runner.
#
# Usage: apt-bootstrap <command> [options]
#   See: apt-bootstrap help

set -euo pipefail

# ---------------------------------------------------------------------------
# Project layout
# ---------------------------------------------------------------------------
#
# TOOL_ROOT   -- always the directory containing this script's bin/ folder.
#                Templates live here; this never changes.
#
# PROJECT_ROOT -- the working root for steps/, state/, and logs/.
#                 Defaults to TOOL_ROOT. Override with APT_BOOTSTRAP_ROOT
#                 to operate on a separate scripts repository while keeping
#                 the tool itself in its own location.
#
#                 Example:
#                   APT_BOOTSTRAP_ROOT=/opt/core-01 apt-bootstrap run --all
# ---------------------------------------------------------------------------

SELF_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOL_ROOT="$(dirname "${SELF_DIR}")"
PROJECT_ROOT="${APT_BOOTSTRAP_ROOT:-${TOOL_ROOT}}"

STEPS_DIR="${PROJECT_ROOT}/steps"
STATE_DIR="${PROJECT_ROOT}/state"
LOGS_DIR="${PROJECT_ROOT}/logs"
TEMPLATES_DIR="${TOOL_ROOT}/templates"

STEP_TEMPLATE="${TEMPLATES_DIR}/step.sh"

# ---------------------------------------------------------------------------
# Terminal colours (disabled when stdout is not a terminal)
# ---------------------------------------------------------------------------

if [[ -t 1 ]]; then
    C_RED='\033[0;31m'
    C_GREEN='\033[0;32m'
    C_YELLOW='\033[0;33m'
    C_BLUE='\033[0;34m'
    C_CYAN='\033[0;36m'
    C_BOLD='\033[1m'
    C_DIM='\033[2m'
    C_RESET='\033[0m'
else
    C_RED='' C_GREEN='' C_YELLOW='' C_BLUE='' C_CYAN='' C_BOLD='' C_DIM='' C_RESET=''
fi

# ---------------------------------------------------------------------------
# Core output utilities
# ---------------------------------------------------------------------------

die() {
    printf '%berror:%b %s\n' "${C_RED}" "${C_RESET}" "$*" >&2
    exit 1
}

warn() {
    printf '%bwarn:%b %s\n' "${C_YELLOW}" "${C_RESET}" "$*" >&2
}

info() {
    printf '%binfo:%b %s\n' "${C_BLUE}" "${C_RESET}" "$*"
}

ok() {
    printf '%bok:%b %s\n' "${C_GREEN}" "${C_RESET}" "$*"
}

# Print a horizontal rule the width of the terminal (or 72 chars).
hr() {
    local width=72
    if command -v tput &>/dev/null && [[ -t 1 ]]; then
        width="$(tput cols 2>/dev/null || echo 72)"
    fi
    printf '%s\n' "$(printf '─%.0s' $(seq 1 "${width}"))"
}

# ---------------------------------------------------------------------------
# Filesystem discovery
# ---------------------------------------------------------------------------

# Ensure the required directories exist (idempotent).
ensure_dirs() {
    mkdir -p "${STEPS_DIR}" "${STATE_DIR}" "${LOGS_DIR}"
}

# Print all step file paths in ascending NNNN order.
find_steps() {
    find "${STEPS_DIR}" -maxdepth 1 -name '[0-9][0-9][0-9][0-9]-*.sh' -type f \
        | sort
}

# Find the single step file for a given 4-digit number.
# Prints the path; returns 1 if not found; dies if multiple matches.
find_step_by_number() {
    local number="$1"
    local matches
    matches="$(find "${STEPS_DIR}" -maxdepth 1 -name "${number}-*.sh" -type f | sort)"
    local count
    count="$(printf '%s' "${matches}" | grep -c '.' || true)"
    if [[ -z "${matches}" ]]; then
        return 1
    fi
    if [[ "${count}" -gt 1 ]]; then
        die "Multiple step files found for number ${number}:${matches}"
    fi
    printf '%s\n' "${matches}"
}

# Extract the 4-digit number from a step file path.
step_number() {
    local base
    base="$(basename "$1")"
    printf '%s\n' "${base:0:4}"
}

# Extract the descriptive name from a step file path (strips NNNN- prefix and .sh suffix).
step_name() {
    local base
    base="$(basename "$1")"
    local stripped="${base#????-}"
    printf '%s\n' "${stripped%.sh}"
}

# Derive the expected state file path for a step file.
state_file_for() {
    local step_path="$1"
    local base
    base="$(basename "${step_path}" .sh)"
    printf '%s\n' "${STATE_DIR}/${base}.state"
}

# Derive a new timestamped log file path for a step file.
new_log_file_for() {
    local step_path="$1"
    local base
    base="$(basename "${step_path}" .sh)"
    local ts
    ts="$(date +%Y%m%d-%H%M%S)"
    printf '%s\n' "${LOGS_DIR}/${base}.${ts}.log"
}

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

validate_number() {
    local number="$1"
    [[ "${number}" =~ ^[0-9]{4}$ ]] \
        || die "Step number must be exactly 4 digits (e.g. 0100): '${number}'"
}

validate_name() {
    local name="$1"
    [[ "${name}" =~ ^[a-z][a-z0-9-]*$ ]] \
        || die "Step name must be lowercase kebab-case beginning with a letter: '${name}'"
}

validate_range_arg() {
    local arg="$1"
    [[ "${arg}" =~ ^[0-9]{4}:[0-9]{4}$ ]] \
        || die "Range must be in the form NNNN:NNNN (e.g. 0100:0300): '${arg}'"
}

# ---------------------------------------------------------------------------
# Checksum
# ---------------------------------------------------------------------------

compute_checksum() {
    local path="$1"
    sha256sum "${path}" | awk '{print $1}'
}

# ---------------------------------------------------------------------------
# State I/O
# ---------------------------------------------------------------------------

# Read a single field from a state file; prints value or empty string.
state_get() {
    local state_file="$1"
    local key="$2"
    if [[ ! -f "${state_file}" ]]; then
        printf ''
        return
    fi
    grep "^${key}=" "${state_file}" | head -1 | cut -d= -f2-
}

# Write the full state file atomically via a temp file.
write_state() {
    local state_file="$1"
    local step="$2"
    local filename="$3"
    local checksum="$4"
    local status="$5"
    local started_at="$6"
    local completed_at="$7"
    local exit_code="$8"
    local log_path="$9"

    local tmp="${state_file}.tmp.$$"
    cat > "${tmp}" <<EOF
step=${step}
filename=${filename}
checksum=${checksum}
status=${status}
started_at=${started_at}
completed_at=${completed_at}
exit_code=${exit_code}
log_path=${log_path}
EOF
    mv "${tmp}" "${state_file}"
}

# ---------------------------------------------------------------------------
# Eligibility determination
# ---------------------------------------------------------------------------
#
# Returns one of:
#   run               -- step should be executed
#   skip-success      -- already succeeded with matching checksum
#   skip-changed      -- succeeded but checksum differs; needs --changed or --force
#   skip-not-failed   -- step is not in failed state (for --failed selector)
#   error-running     -- step left in 'running' state; needs --force
#   error-failed      -- step previously failed; needs --failed or --force
#   error-unknown     -- state file has an unrecognised status
#
# Parameters:
#   $1  step_path
#   $2  selector  (all | changed | failed | step | range | first | last)
#   $3  force     (true | false)
#
step_eligibility() {
    local step_path="$1"
    local selector="$2"
    local force="$3"

    local state_file
    state_file="$(state_file_for "${step_path}")"
    local current_checksum
    current_checksum="$(compute_checksum "${step_path}")"

    # No state file: the step has never run.
    if [[ ! -f "${state_file}" ]]; then
        if [[ "${selector}" == "failed" ]]; then
            printf 'skip-not-failed'
        else
            printf 'run'
        fi
        return
    fi

    local recorded_status recorded_checksum
    recorded_status="$(state_get "${state_file}" status)"
    recorded_checksum="$(state_get "${state_file}" checksum)"

    # 'running' always requires explicit acknowledgement, even with --force.
    if [[ "${recorded_status}" == "running" ]]; then
        if [[ "${force}" == "true" ]]; then
            # Force allows overriding an interrupted run.
            if [[ "${selector}" == "failed" ]]; then
                printf 'skip-not-failed'
            else
                printf 'run'
            fi
        else
            printf 'error-running'
        fi
        return
    fi

    # --force bypasses all success/failed guards.
    if [[ "${force}" == "true" ]]; then
        if [[ "${selector}" == "failed" ]]; then
            if [[ "${recorded_status}" == "failed" ]]; then
                printf 'run'
            else
                printf 'skip-not-failed'
            fi
        else
            printf 'run'
        fi
        return
    fi

    # Normal (no --force) eligibility rules per status.
    case "${recorded_status}" in
        success)
            if [[ "${current_checksum}" == "${recorded_checksum}" ]]; then
                # Unchanged: always skip regardless of selector.
                printf 'skip-success'
            else
                # Content changed since last success.
                if [[ "${selector}" == "changed" ]]; then
                    printf 'run'
                elif [[ "${selector}" == "failed" ]]; then
                    printf 'skip-not-failed'
                else
                    printf 'skip-changed'
                fi
            fi
            ;;
        failed)
            if [[ "${selector}" == "failed" ]]; then
                printf 'run'
            elif [[ "${selector}" == "changed" ]]; then
                # A failed step is not "changed" in the checksum sense.
                printf 'skip-not-failed'
            else
                printf 'error-failed'
            fi
            ;;
        pending|"")
            if [[ "${selector}" == "failed" ]]; then
                printf 'skip-not-failed'
            else
                printf 'run'
            fi
            ;;
        *)
            printf 'error-unknown'
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Step execution
# ---------------------------------------------------------------------------

# Execute a single step, writing state before and after.
# Returns 0 on success, exits via die() on step failure.
execute_step() {
    local step_path="$1"

    local number name filename state_file current_checksum log_file started_at
    number="$(step_number "${step_path}")"
    name="$(step_name "${step_path}")"
    filename="$(basename "${step_path}")"
    state_file="$(state_file_for "${step_path}")"
    current_checksum="$(compute_checksum "${step_path}")"
    log_file="$(new_log_file_for "${step_path}")"
    started_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    printf '\n%b==> Step %s: %s%b\n' "${C_BOLD}" "${number}" "${name}" "${C_RESET}"
    printf '    %blog:%b %s\n' "${C_DIM}" "${C_RESET}" "${log_file}"

    # Mark the step as running before execution.
    write_state "${state_file}" \
        "${number}" "${filename}" "${current_checksum}" \
        "running" "${started_at}" "" "" "${log_file}"

    # Write a header block to the log file.
    {
        printf '# Step:      %s\n' "${filename}"
        printf '# Started:   %s\n' "${started_at}"
        printf '# Checksum:  %s\n' "${current_checksum}"
        printf '# ---\n'
    } > "${log_file}"

    # Execute the step. Temporarily suspend errexit and pipefail so we can
    # capture the exit code from the left side of the pipe.
    local step_exit_code=0
    set +eo pipefail
    bash "${step_path}" 2>&1 | tee -a "${log_file}"
    step_exit_code="${PIPESTATUS[0]}"
    set -eo pipefail

    local completed_at
    completed_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

    # Append a footer to the log file.
    {
        printf '# ---\n'
        printf '# Completed: %s\n' "${completed_at}"
        printf '# Exit code: %s\n' "${step_exit_code}"
    } >> "${log_file}"

    if [[ "${step_exit_code}" -eq 0 ]]; then
        write_state "${state_file}" \
            "${number}" "${filename}" "${current_checksum}" \
            "success" "${started_at}" "${completed_at}" "${step_exit_code}" "${log_file}"
        ok "Step ${number} (${filename}) succeeded."
    else
        write_state "${state_file}" \
            "${number}" "${filename}" "${current_checksum}" \
            "failed" "${started_at}" "${completed_at}" "${step_exit_code}" "${log_file}"
        printf '%berror:%b Step %s (%s) failed with exit code %s.\n' \
            "${C_RED}" "${C_RESET}" "${number}" "${filename}" "${step_exit_code}" >&2
        printf '       Log: %s\n' "${log_file}" >&2
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Command: list
# ---------------------------------------------------------------------------

cmd_list() {
    ensure_dirs

    local steps=()
    while IFS= read -r _l; do steps+=("${_l}"); done < <(find_steps)

    if [[ ${#steps[@]} -eq 0 ]]; then
        info "No steps found in ${STEPS_DIR}."
        return
    fi

    printf '\n'
    printf '%b%-6s  %-30s  %-10s  %s%b\n' \
        "${C_BOLD}" "STEP" "FILENAME" "STATUS" "NOTE" "${C_RESET}"
    hr

    local step_path number filename state_file status checksum current_checksum note colour
    for step_path in "${steps[@]}"; do
        number="$(step_number "${step_path}")"
        filename="$(basename "${step_path}")"
        state_file="$(state_file_for "${step_path}")"
        note=""
        colour="${C_RESET}"

        if [[ -f "${state_file}" ]]; then
            status="$(state_get "${state_file}" status)"
            checksum="$(state_get "${state_file}" checksum)"
            current_checksum="$(compute_checksum "${step_path}")"

            case "${status}" in
                success)
                    if [[ "${current_checksum}" != "${checksum}" ]]; then
                        note="[CHANGED] checksum differs from last success"
                        colour="${C_YELLOW}"
                    else
                        colour="${C_GREEN}"
                    fi
                    ;;
                failed)
                    colour="${C_RED}"
                    ;;
                running)
                    note="[INTERRUPTED?] left in running state"
                    colour="${C_YELLOW}"
                    ;;
                *)
                    note="[UNKNOWN STATUS]"
                    colour="${C_YELLOW}"
                    ;;
            esac
        else
            status="pending"
            colour="${C_CYAN}"
        fi

        printf '%b%-6s  %-30s  %-10s  %s%b\n' \
            "${colour}" "${number}" "${filename}" "${status}" "${note}" "${C_RESET}"
    done
    printf '\n'
}

# ---------------------------------------------------------------------------
# Command: create
# ---------------------------------------------------------------------------

cmd_create() {
    if [[ $# -lt 2 ]]; then
        die "Usage: apt-bootstrap create NNNN name"
    fi

    local number="$1"
    local name="$2"

    validate_number "${number}"
    validate_name "${name}"
    ensure_dirs

    if find_step_by_number "${number}" &>/dev/null; then
        die "A step with number ${number} already exists: $(find_step_by_number "${number}")"
    fi

    if [[ ! -f "${STEP_TEMPLATE}" ]]; then
        die "Step template not found: ${STEP_TEMPLATE}"
    fi

    local filename="${number}-${name}.sh"
    local dest="${STEPS_DIR}/${filename}"

    sed \
        -e "s/__STEP_NUMBER__/${number}/g" \
        -e "s/__STEP_NAME__/${name}/g" \
        "${STEP_TEMPLATE}" > "${dest}"

    chmod +x "${dest}"
    ok "Created: ${dest}"
    info "Edit the step file, then run: apt-bootstrap run --step ${number}"
}

# ---------------------------------------------------------------------------
# Command: rename
# ---------------------------------------------------------------------------

cmd_rename() {
    if [[ $# -lt 2 ]]; then
        die "Usage: apt-bootstrap rename NNNN new-name"
    fi

    local number="$1"
    local new_name="$2"

    validate_number "${number}"
    validate_name "${new_name}"
    ensure_dirs

    local old_path
    old_path="$(find_step_by_number "${number}")" \
        || die "No step found with number ${number}."

    local old_filename
    old_filename="$(basename "${old_path}")"
    local old_name
    old_name="$(step_name "${old_path}")"

    if [[ "${old_name}" == "${new_name}" ]]; then
        die "Step ${number} is already named '${new_name}'."
    fi

    local new_filename="${number}-${new_name}.sh"
    local new_path="${STEPS_DIR}/${new_filename}"

    if [[ -e "${new_path}" ]]; then
        die "Destination already exists: ${new_path}"
    fi

    # Rename step file.
    mv "${old_path}" "${new_path}"

    # Migrate state file if it exists.
    local old_state="${STATE_DIR}/${old_filename%.sh}.state"
    local new_state="${STATE_DIR}/${new_filename%.sh}.state"
    if [[ -f "${old_state}" ]]; then
        # Update the filename field inside the state file.
        sed "s/^filename=.*/filename=${new_filename}/" "${old_state}" > "${new_state}"
        rm "${old_state}"
        info "State file migrated: $(basename "${old_state}") -> $(basename "${new_state}")"
    fi

    # Migrate log files if any exist (rename pattern NNNN-old-name.*.log).
    local old_log_prefix="${LOGS_DIR}/${old_filename%.sh}."
    local new_log_prefix="${LOGS_DIR}/${new_filename%.sh}."
    local log_file renamed_log
    while IFS= read -r log_file; do
        renamed_log="${new_log_prefix}${log_file#"${old_log_prefix}"}"
        mv "${log_file}" "${renamed_log}"
        printf '# Renamed from: %s\n' "${log_file}" >> "${renamed_log}"
        info "Log migrated: $(basename "${log_file}") -> $(basename "${renamed_log}")"
    done < <(find "${LOGS_DIR}" -maxdepth 1 -name "${old_filename%.sh}.*.log" -type f | sort)

    ok "Renamed step ${number}: '${old_name}' -> '${new_name}'"
    info "File: ${new_path}"
}

# ---------------------------------------------------------------------------
# Command: move
# ---------------------------------------------------------------------------
#
# Moves the numeric prefix of a step (OLD_NNNN -> NEW_NNNN).
# The descriptive name is preserved.
#
# State and logs are renamed to match the new number. The state file's
# filename field is updated. The checksum remains valid because it is
# computed from file contents, not the filename.
#
# Behaviour on conflict: refuses if NEW_NNNN already has a step file.

cmd_move() {
    if [[ $# -lt 2 ]]; then
        die "Usage: apt-bootstrap move OLD_NNNN NEW_NNNN"
    fi

    local old_number="$1"
    local new_number="$2"

    validate_number "${old_number}"
    validate_number "${new_number}"
    ensure_dirs

    local old_path
    old_path="$(find_step_by_number "${old_number}")" \
        || die "No step found with number ${old_number}."

    if find_step_by_number "${new_number}" &>/dev/null; then
        die "A step with number ${new_number} already exists: $(find_step_by_number "${new_number}")"
    fi

    local name
    name="$(step_name "${old_path}")"
    local old_filename
    old_filename="$(basename "${old_path}")"
    local new_filename="${new_number}-${name}.sh"
    local new_path="${STEPS_DIR}/${new_filename}"

    # Move step file.
    mv "${old_path}" "${new_path}"

    # Migrate state file.
    local old_state="${STATE_DIR}/${old_filename%.sh}.state"
    local new_state="${STATE_DIR}/${new_filename%.sh}.state"
    if [[ -f "${old_state}" ]]; then
        sed -e "s/^step=.*/step=${new_number}/" \
            -e "s/^filename=.*/filename=${new_filename}/" \
            "${old_state}" > "${new_state}"
        rm "${old_state}"
        info "State file migrated: $(basename "${old_state}") -> $(basename "${new_state}")"
    fi

    # Migrate log files.
    local old_log_prefix="${LOGS_DIR}/${old_filename%.sh}."
    local new_log_prefix="${LOGS_DIR}/${new_filename%.sh}."
    local log_file renamed_log
    while IFS= read -r log_file; do
        renamed_log="${new_log_prefix}${log_file#"${old_log_prefix}"}"
        mv "${log_file}" "${renamed_log}"
        printf '# Moved from step: %s -> %s\n' "${old_filename}" "${new_filename}" >> "${renamed_log}"
        info "Log migrated: $(basename "${log_file}") -> $(basename "${renamed_log}")"
    done < <(find "${LOGS_DIR}" -maxdepth 1 -name "${old_filename%.sh}.*.log" -type f | sort)

    ok "Moved step '${name}': ${old_number} -> ${new_number}"
    info "File: ${new_path}"
}

# ---------------------------------------------------------------------------
# Command: delete
# ---------------------------------------------------------------------------
#
# Removes a step file. By default, preserves state and logs.
# Use --purge to also remove associated state and log files.
# Requires confirmation unless --force is given.

cmd_delete() {
    if [[ $# -lt 1 ]]; then
        die "Usage: apt-bootstrap delete NNNN [--force] [--purge]"
    fi

    local number="$1"
    local force=false
    local purge=false
    shift

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=true ;;
            --purge)    purge=true ;;
            *) die "Unknown option for delete: $1" ;;
        esac
        shift
    done

    validate_number "${number}"
    ensure_dirs

    local step_path
    step_path="$(find_step_by_number "${number}")" \
        || die "No step found with number ${number}."

    local filename
    filename="$(basename "${step_path}")"

    if [[ "${force}" != "true" ]]; then
        printf 'Delete step file: %s\n' "${step_path}"
        if [[ "${purge}" == "true" ]]; then
            printf 'Also remove: state and log files for %s\n' "${filename%.sh}"
        else
            printf 'State and log files will be preserved.\n'
        fi
        printf 'Confirm? [y/N] '
        local answer
        read -r answer
        [[ "${answer}" =~ ^[Yy]$ ]] || { info "Aborted."; return; }
    fi

    rm "${step_path}"
    ok "Deleted step file: ${step_path}"

    if [[ "${purge}" == "true" ]]; then
        local state_file="${STATE_DIR}/${filename%.sh}.state"
        if [[ -f "${state_file}" ]]; then
            rm "${state_file}"
            info "Removed state: ${state_file}"
        fi
        local log_file
        while IFS= read -r log_file; do
            rm "${log_file}"
            info "Removed log: ${log_file}"
        done < <(find "${LOGS_DIR}" -maxdepth 1 -name "${filename%.sh}.*.log" -type f | sort)
    else
        local state_file="${STATE_DIR}/${filename%.sh}.state"
        if [[ -f "${state_file}" ]]; then
            info "State preserved: ${state_file}  (use --purge to remove)"
        fi
        local log_count
        log_count="$(find "${LOGS_DIR}" -maxdepth 1 -name "${filename%.sh}.*.log" -type f | wc -l | tr -d ' ')"
        if [[ "${log_count}" -gt 0 ]]; then
            info "${log_count} log file(s) preserved in ${LOGS_DIR}/  (use --purge to remove)"
        fi
    fi
}

# ---------------------------------------------------------------------------
# Command: run
# ---------------------------------------------------------------------------

cmd_run() {
    if [[ $# -eq 0 ]]; then
        die "Usage: apt-bootstrap run --all|--first|--last|--step NNNN|--range NNNN:NNNN|--changed|--failed [--force] [--list-only]"
    fi

    local selector=""
    local selector_arg=""
    local force=false
    local list_only=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all)      selector="all" ;;
            --first)    selector="first" ;;
            --last)     selector="last" ;;
            --changed)  selector="changed" ;;
            --failed)   selector="failed" ;;
            --step)
                [[ $# -ge 2 ]] || die "--step requires a NNNN argument."
                selector="step"
                selector_arg="$2"
                shift
                ;;
            --range)
                [[ $# -ge 2 ]] || die "--range requires a NNNN:NNNN argument."
                selector="range"
                selector_arg="$2"
                shift
                ;;
            --force)     force=true ;;
            --list-only) list_only=true ;;
            *) die "Unknown run option: $1" ;;
        esac
        shift
    done

    [[ -n "${selector}" ]] || die "Specify a run selector: --all, --first, --last, --step, --range, --changed, or --failed."

    ensure_dirs

    # Validate selector-specific arguments.
    if [[ "${selector}" == "step" ]]; then
        validate_number "${selector_arg}"
    elif [[ "${selector}" == "range" ]]; then
        validate_range_arg "${selector_arg}"
        local range_lo="${selector_arg%%:*}"
        local range_hi="${selector_arg##*:}"
        [[ "${range_lo}" -le "${range_hi}" ]] \
            || die "Range start (${range_lo}) must be <= range end (${range_hi})."
    fi

    # Collect candidate steps.
    local candidates=()
    case "${selector}" in
        all|changed|failed)
            while IFS= read -r _l; do candidates+=("${_l}"); done < <(find_steps)
            ;;
        first)
            local first
            first="$(find_steps | head -1)"
            [[ -n "${first}" ]] || die "No steps found."
            candidates=("${first}")
            ;;
        last)
            local last
            last="$(find_steps | tail -1)"
            [[ -n "${last}" ]] || die "No steps found."
            candidates=("${last}")
            ;;
        step)
            local step_path
            step_path="$(find_step_by_number "${selector_arg}")" \
                || die "Step ${selector_arg} not found."
            candidates=("${step_path}")
            ;;
        range)
            local lo="${selector_arg%%:*}" hi="${selector_arg##*:}"
            while IFS= read -r step_path; do
                local n
                n="$(step_number "${step_path}")"
                if [[ "${n}" -ge "${lo}" && "${n}" -le "${hi}" ]]; then
                    candidates+=("${step_path}")
                fi
            done < <(find_steps)
            ;;
    esac

    if [[ ${#candidates[@]} -eq 0 ]]; then
        info "No steps matched the selection."
        return
    fi

    # Evaluate eligibility for each candidate and execute or report.
    local changed_steps=()
    local skipped_steps=()
    local ran_count=0
    local step_path eligibility

    for step_path in "${candidates[@]}"; do
        local number filename
        number="$(step_number "${step_path}")"
        filename="$(basename "${step_path}")"

        eligibility="$(step_eligibility "${step_path}" "${selector}" "${force}")"

        if [[ "${list_only}" == "true" ]]; then
            # --list-only: report what would happen without running.
            case "${eligibility}" in
                run)
                    printf '  %b[WOULD RUN]%b  %s\n' "${C_GREEN}" "${C_RESET}" "${filename}"
                    ;;
                skip-success)
                    printf '  %b[SKIP]%b       %s  (success, unchanged)\n' "${C_DIM}" "${C_RESET}" "${filename}"
                    ;;
                skip-changed)
                    printf '  %b[SKIP/WARN]%b  %s  (changed -- use --changed or --force)\n' "${C_YELLOW}" "${C_RESET}" "${filename}"
                    ;;
                skip-not-failed)
                    printf '  %b[SKIP]%b       %s  (not in failed state)\n' "${C_DIM}" "${C_RESET}" "${filename}"
                    ;;
                error-running)
                    printf '  %b[BLOCKED]%b    %s  (interrupted running state -- use --force)\n' "${C_RED}" "${C_RESET}" "${filename}"
                    ;;
                error-failed)
                    printf '  %b[BLOCKED]%b    %s  (previously failed -- use --failed or --force)\n' "${C_RED}" "${C_RESET}" "${filename}"
                    ;;
                error-unknown)
                    printf '  %b[BLOCKED]%b    %s  (unknown state)\n' "${C_RED}" "${C_RESET}" "${filename}"
                    ;;
            esac
            continue
        fi

        # Actual run mode.
        case "${eligibility}" in
            run)
                execute_step "${step_path}"
                (( ran_count++ )) || true
                ;;
            skip-success)
                printf '  %b[skip]%b  %s  (already succeeded, checksum unchanged)\n' \
                    "${C_DIM}" "${C_RESET}" "${filename}"
                skipped_steps+=("${filename}")
                ;;
            skip-changed)
                printf '%bwarn:%b  Step %s has changed since last success.\n' \
                    "${C_YELLOW}" "${C_RESET}" "${number}" >&2
                printf '       Use --changed or --force to rerun: %s\n' "${filename}" >&2
                changed_steps+=("${filename}")
                ;;
            skip-not-failed)
                printf '  %b[skip]%b  %s  (not in failed state)\n' \
                    "${C_DIM}" "${C_RESET}" "${filename}"
                skipped_steps+=("${filename}")
                ;;
            error-running)
                die "Step ${number} (${filename}) is in 'running' state from an interrupted execution. Use --force to override."
                ;;
            error-failed)
                die "Step ${number} (${filename}) previously failed. Use --failed to retry or --force to override."
                ;;
            error-unknown)
                die "Step ${number} (${filename}) has an unrecognised status in its state file."
                ;;
        esac
    done

    if [[ "${list_only}" == "true" ]]; then
        return
    fi

    # Final summary.
    printf '\n'
    hr
    if [[ "${ran_count}" -gt 0 ]]; then
        ok "${ran_count} step(s) ran successfully."
    else
        info "No steps were executed."
    fi
    if [[ ${#changed_steps[@]} -gt 0 ]]; then
        warn "${#changed_steps[@]} changed step(s) were skipped: ${changed_steps[*]}"
        warn "Run 'apt-bootstrap run --changed' or 'apt-bootstrap run --force' to rerun them."
    fi
}

# ---------------------------------------------------------------------------
# Command: state
# ---------------------------------------------------------------------------

# Print a formatted summary of a single state file.
print_state_summary() {
    local state_file="$1"
    local step filename checksum status started_at completed_at exit_code log_path

    step="$(state_get "${state_file}" step)"
    filename="$(state_get "${state_file}" filename)"
    checksum="$(state_get "${state_file}" checksum)"
    status="$(state_get "${state_file}" status)"
    started_at="$(state_get "${state_file}" started_at)"
    completed_at="$(state_get "${state_file}" completed_at)"
    exit_code="$(state_get "${state_file}" exit_code)"
    log_path="$(state_get "${state_file}" log_path)"

    # Determine if the current file's checksum matches.
    local step_path="${STEPS_DIR}/${filename}"
    local checksum_note=""
    if [[ -f "${step_path}" ]]; then
        local current_checksum
        current_checksum="$(compute_checksum "${step_path}")"
        if [[ "${current_checksum}" != "${checksum}" ]]; then
            checksum_note="  ${C_YELLOW}[FILE CHANGED]${C_RESET}"
        fi
    else
        checksum_note="  ${C_RED}[STEP FILE MISSING]${C_RESET}"
    fi

    local status_colour="${C_RESET}"
    case "${status}" in
        success) status_colour="${C_GREEN}" ;;
        failed)  status_colour="${C_RED}" ;;
        running) status_colour="${C_YELLOW}" ;;
    esac

    printf '\n'
    printf '  %-16s %s\n' "Step:"       "${step}"
    printf '  %-16s %s\n' "Filename:"   "${filename}"
    printf '  %-16s %s%b\n' "Checksum:"   "${checksum}" "${checksum_note}"
    printf '  %-16s %b%s%b\n' "Status:"    "${status_colour}" "${status}" "${C_RESET}"
    printf '  %-16s %s\n' "Started:"    "${started_at:-—}"
    printf '  %-16s %s\n' "Completed:"  "${completed_at:-—}"
    printf '  %-16s %s\n' "Exit code:"  "${exit_code:-—}"
    printf '  %-16s %s\n' "Log:"        "${log_path:-—}"
    printf '\n'
}

cmd_state() {
    if [[ $# -eq 0 ]]; then
        die "Usage: apt-bootstrap state show [NNNN] | clear NNNN | clear-range NNNN NNNN | clear-all"
    fi

    local subcommand="$1"
    shift

    case "${subcommand}" in

        show)
            ensure_dirs
            if [[ $# -eq 0 ]]; then
                # Show all steps.
                local steps=()
                while IFS= read -r _l; do steps+=("${_l}"); done < <(find_steps)
                if [[ ${#steps[@]} -eq 0 ]]; then
                    info "No steps found."
                    return
                fi
                for step_path in "${steps[@]}"; do
                    local filename state_file
                    filename="$(basename "${step_path}")"
                    state_file="$(state_file_for "${step_path}")"
                    hr
                    printf '%b%s%b\n' "${C_BOLD}" "${filename}" "${C_RESET}"
                    if [[ -f "${state_file}" ]]; then
                        print_state_summary "${state_file}"
                    else
                        printf '  %b(no state -- never run)%b\n\n' "${C_DIM}" "${C_RESET}"
                    fi
                done
            else
                # Show one step.
                local number="$1"
                validate_number "${number}"
                local step_path
                step_path="$(find_step_by_number "${number}")" \
                    || die "Step ${number} not found."
                local state_file
                state_file="$(state_file_for "${step_path}")"
                if [[ -f "${state_file}" ]]; then
                    hr
                    printf '%b%s%b\n' "${C_BOLD}" "$(basename "${step_path}")" "${C_RESET}"
                    print_state_summary "${state_file}"
                else
                    info "No state for step ${number} -- it has never run."
                fi
            fi
            ;;

        clear)
            [[ $# -ge 1 ]] || die "Usage: apt-bootstrap state clear NNNN"
            local number="$1"
            validate_number "${number}"
            ensure_dirs
            local step_path
            step_path="$(find_step_by_number "${number}")" \
                || die "Step ${number} not found."
            local state_file
            state_file="$(state_file_for "${step_path}")"
            if [[ -f "${state_file}" ]]; then
                rm "${state_file}"
                ok "State cleared for step ${number}."
            else
                info "No state file exists for step ${number}."
            fi
            ;;

        clear-range)
            [[ $# -ge 2 ]] || die "Usage: apt-bootstrap state clear-range NNNN NNNN"
            local lo="$1" hi="$2"
            validate_number "${lo}"
            validate_number "${hi}"
            [[ "${lo}" -le "${hi}" ]] || die "Range start must be <= range end."
            ensure_dirs
            local cleared=0
            local step_path
            while IFS= read -r step_path; do
                local n
                n="$(step_number "${step_path}")"
                if [[ "${n}" -ge "${lo}" && "${n}" -le "${hi}" ]]; then
                    local state_file
                    state_file="$(state_file_for "${step_path}")"
                    if [[ -f "${state_file}" ]]; then
                        rm "${state_file}"
                        info "Cleared state for step ${n}."
                        (( cleared++ )) || true
                    fi
                fi
            done < <(find_steps)
            ok "Cleared ${cleared} state file(s) in range ${lo}-${hi}."
            ;;

        clear-all)
            ensure_dirs
            local cleared=0
            local f
            while IFS= read -r f; do
                rm "${f}"
                info "Cleared: $(basename "${f}")"
                (( cleared++ )) || true
            done < <(find "${STATE_DIR}" -maxdepth 1 -name '*.state' -type f | sort)
            ok "Cleared ${cleared} state file(s)."
            ;;

        *)
            die "Unknown state subcommand: '${subcommand}'. Use: show, clear, clear-range, clear-all."
            ;;
    esac
}

# ---------------------------------------------------------------------------
# Command: doctor
# ---------------------------------------------------------------------------

cmd_doctor() {
    ensure_dirs
    local issues=0
    local step_path number filename state_file

    printf '\n%bDiagnostic report%b\n' "${C_BOLD}" "${C_RESET}"
    hr

    # Check for steps in inconsistent state.
    while IFS= read -r step_path; do
        number="$(step_number "${step_path}")"
        filename="$(basename "${step_path}")"
        state_file="$(state_file_for "${step_path}")"

        if [[ -f "${state_file}" ]]; then
            local status
            status="$(state_get "${state_file}" status)"

            if [[ "${status}" == "running" ]]; then
                printf '%b[WARN]%b  Step %s left in running state (interrupted?): %s\n' \
                    "${C_YELLOW}" "${C_RESET}" "${number}" "${filename}"
                (( issues++ )) || true
            fi

            if [[ "${status}" == "failed" ]]; then
                printf '%b[WARN]%b  Step %s is in failed state: %s\n' \
                    "${C_YELLOW}" "${C_RESET}" "${number}" "${filename}"
                (( issues++ )) || true
            fi

            if [[ "${status}" == "success" ]]; then
                local recorded_checksum current_checksum
                recorded_checksum="$(state_get "${state_file}" checksum)"
                current_checksum="$(compute_checksum "${step_path}")"
                if [[ "${current_checksum}" != "${recorded_checksum}" ]]; then
                    printf '%b[INFO]%b  Step %s has changed since last success: %s\n' \
                        "${C_CYAN}" "${C_RESET}" "${number}" "${filename}"
                    (( issues++ )) || true
                fi
            fi
        fi

        if [[ ! -x "${step_path}" ]]; then
            printf '%b[ERROR]%b Step %s is not executable: %s\n' \
                "${C_RED}" "${C_RESET}" "${number}" "${filename}"
            (( issues++ )) || true
        fi
    done < <(find_steps)

    # Check for orphaned state files (no matching step file).
    local state_f step_basename
    while IFS= read -r state_f; do
        step_basename="$(basename "${state_f}" .state)"
        if [[ ! -f "${STEPS_DIR}/${step_basename}.sh" ]]; then
            printf '%b[INFO]%b  Orphaned state file (no matching step): %s\n' \
                "${C_CYAN}" "${C_RESET}" "$(basename "${state_f}")"
            (( issues++ )) || true
        fi
    done < <(find "${STATE_DIR}" -maxdepth 1 -name '*.state' -type f | sort)

    if [[ "${issues}" -eq 0 ]]; then
        ok "All clear. No issues detected."
    else
        printf '\n%b%d issue(s) found.%b\n' "${C_YELLOW}" "${issues}" "${C_RESET}"
    fi
    printf '\n'
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------

cmd_help() {
    cat <<'EOF'

apt-bootstrap -- Step-based server provisioning runner

USAGE
  apt-bootstrap <command> [options]

COMMANDS

  list
      Show all steps with status and change indicators.

  create NNNN name
      Create a new step file from the template.
      NNNN: 4-digit zero-padded number (e.g. 0100)
      name: lowercase kebab-case (e.g. install-packages)

  rename NNNN new-name
      Rename the descriptive portion of an existing step.
      Migrates state and log files to match the new name.

  move OLD_NNNN NEW_NNNN
      Change the numeric prefix of a step.
      Migrates state and log files to match the new number.

  delete NNNN [--force] [--purge]
      Remove a step file. Requires confirmation unless --force.
      --purge: also remove associated state and log files.
      Default: state and logs are preserved.

  run SELECTOR [--force] [--list-only]
    Selectors (pick one):
      --all             Run all steps (skip succeeded+unchanged; stop on failed/changed)
      --first           Run the lowest-numbered step
      --last            Run the highest-numbered step
      --step NNNN       Run one specific step
      --range NNNN:NNNN Run steps in the inclusive numeric range
      --changed         Run steps with no state or changed checksum since last success
      --failed          Run only steps in failed state
    Modifiers:
      --force           Ignore success/failed state; always run the selected step(s)
      --list-only       Show what would run without executing anything

  state show [NNNN]
      Show state for all steps, or a specific step.

  state clear NNNN
      Remove state file for a step (marks it as never-run).

  state clear-range NNNN NNNN
      Remove state files for steps in the inclusive range.

  state clear-all
      Remove all state files.

  doctor
      Check for interrupted runs, failures, changed steps, and orphaned files.

  help
      Show this message.

EOF
}

# ---------------------------------------------------------------------------
# Main dispatcher
# ---------------------------------------------------------------------------

main() {
    if [[ $# -eq 0 ]]; then
        cmd_help
        exit 0
    fi

    local command="$1"
    shift

    case "${command}" in
        list)         cmd_list "$@" ;;
        create)       cmd_create "$@" ;;
        rename)       cmd_rename "$@" ;;
        move)         cmd_move "$@" ;;
        delete)       cmd_delete "$@" ;;
        run)          cmd_run "$@" ;;
        state)        cmd_state "$@" ;;
        doctor)       cmd_doctor "$@" ;;
        help|--help|-h) cmd_help ;;
        *)
            printf 'error: Unknown command: %s\n' "${command}" >&2
            printf 'Run: apt-bootstrap help\n' >&2
            exit 1
            ;;
    esac
}

main "$@"
